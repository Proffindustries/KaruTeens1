PORT=3000
MONGO_URI=mongodb+srv://...
MONGO_MAX_POOL_SIZE=100
MONGO_MIN_POOL_SIZE=10
REDIS_URL=redis://127.0.0.1:6379
REDIS_PRESENCE_TTL=300
REDIS_MONGO_UPDATE_TTL=60
JWT_SECRET=your_secret
FRONTEND_URL=https://www.karuteens.site,https://karuteens.site,http://localhost:5173
RUST_LOG=karuteens_backend=debug
BREVO_API_KEY=...

# Cache Settings (optional, defaults provided)
CACHE_FEED_TTL=300
CACHE_PROFILE_TTL=3600
CACHE_USER_TTL=1800
CACHE_TRENDING_TTL=600
CACHE_LIST_TTL=300

# M-Pesa Configuration
MPESA_ENV=sandbox
MPESA_CONSUMER_KEY=...
MPESA_CONSUMER_SECRET=...
MPESA_BUSINESS_SHORTCODE=...
MPESA_PASSKEY=...
MPESA_PARTYB=...
MPESA_TRANSACTION_TYPE=CustomerPayBillOnline

# Cloudinary
CLOUDINARY_API_SECRET=...

# CDN (Cloudflare R2)
CDN_URL=...
R2_ACCOUNT_ID=...
R2_ACCESS_KEY_ID=...
R2_SECRET_ACCESS_KEY=...
R2_BUCKET=...
R2_PUBLIC_BASE_URL=...
CDN_CACHE_TTL=86400
CDN_IMAGE_OPTIMIZATION=true

# Ably (real-time messaging)
ABLY_API_KEY=...

# OpenRouter (AI)
OPENROUTER_API_KEY=...

# Push Notifications
VAPID_PUBLIC_KEY=...

# Base URL
BASE_URL=https://api.karuteens.site

# Media URL
MEDIA_URL=https://media.karuteens.site
